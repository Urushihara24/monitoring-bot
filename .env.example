# Telegram Bot (получите у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=123456789

# GGSEL API
# API key или JWT access token
GGSEL_API_KEY=your_api_key_here
# Если GGSEL_API_KEY это JWT, укажите отдельный секрет для /apilogin:
GGSEL_API_SECRET=
# Опционально: готовый access token (если хотите задать вручную)
GGSEL_ACCESS_TOKEN=
GGSEL_SELLER_ID=8175
GGSEL_PRODUCT_ID=your_product_id_here
GGSEL_LANG=ru-RU
# true = не запускаться, если API недоступен на старте
GGSEL_REQUIRE_API_ON_START=false
GGSEL_ENABLED=true
# Авто-отправка инструкции в чат заказа (GGSEL)
GGSEL_CHAT_AUTOREPLY_ENABLED=false
# Список product_id через запятую; если пусто, используется GGSEL_PRODUCT_ID
GGSEL_CHAT_AUTOREPLY_PRODUCT_IDS=
GGSEL_CHAT_AUTOREPLY_PAGE_SIZE=50
GGSEL_CHAT_AUTOREPLY_MAX_PAGES=2
GGSEL_CHAT_AUTOREPLY_INTERVAL_SECONDS=30
GGSEL_CHAT_AUTOREPLY_DEDUPE_BY_MESSAGES=true
GGSEL_CHAT_AUTOREPLY_LOOKBACK_MESSAGES=30
GGSEL_CHAT_AUTOREPLY_SENT_TTL_DAYS=30
GGSEL_CHAT_AUTOREPLY_CLEANUP_EVERY_HOURS=24
# Опциональные шаблоны (если пусто, берём info/add_info из товара)
GGSEL_CHAT_TEMPLATE_RU_ALREADY=
GGSEL_CHAT_TEMPLATE_RU_ADD=
GGSEL_CHAT_TEMPLATE_EN_ALREADY=
GGSEL_CHAT_TEMPLATE_EN_ADD=

# DigiSeller API (второй профиль)
DIGISELLER_ENABLED=false
DIGISELLER_API_KEY=
DIGISELLER_API_SECRET=
DIGISELLER_ACCESS_TOKEN=
DIGISELLER_SELLER_ID=
DIGISELLER_PRODUCT_ID=
DIGISELLER_BASE_URL=https://api.digiseller.com/api
DIGISELLER_LANG=ru-RU
DIGISELLER_REQUIRE_API_ON_START=false
DIGISELLER_COMPETITOR_URLS=
# Авто-отправка инструкции в чат заказа (DigiSeller)
DIGISELLER_CHAT_AUTOREPLY_ENABLED=false
# Список product_id через запятую; если пусто, используется DIGISELLER_PRODUCT_ID
DIGISELLER_CHAT_AUTOREPLY_PRODUCT_IDS=
DIGISELLER_CHAT_AUTOREPLY_PAGE_SIZE=50
DIGISELLER_CHAT_AUTOREPLY_MAX_PAGES=2
DIGISELLER_CHAT_AUTOREPLY_INTERVAL_SECONDS=30
DIGISELLER_CHAT_AUTOREPLY_DEDUPE_BY_MESSAGES=true
DIGISELLER_CHAT_AUTOREPLY_LOOKBACK_MESSAGES=30
DIGISELLER_CHAT_AUTOREPLY_SENT_TTL_DAYS=30
DIGISELLER_CHAT_AUTOREPLY_CLEANUP_EVERY_HOURS=24
# Опциональные шаблоны (если пусто, берём info/add_info из товара)
DIGISELLER_CHAT_TEMPLATE_RU_ALREADY=
DIGISELLER_CHAT_TEMPLATE_RU_ADD=
DIGISELLER_CHAT_TEMPLATE_EN_ALREADY=
DIGISELLER_CHAT_TEMPLATE_EN_ADD=
# Опциональные профильные runtime-дефолты DigiSeller
# (применяются при первом запуске, если ключа ещё нет в runtime_settings):
DIGISELLER_MIN_PRICE=
DIGISELLER_MAX_PRICE=
DIGISELLER_DESIRED_PRICE=
DIGISELLER_UNDERCUT_VALUE=
DIGISELLER_MODE=
DIGISELLER_FIXED_PRICE=
DIGISELLER_STEP_UP_VALUE=
DIGISELLER_WEAK_PRICE_CEIL_LIMIT=
DIGISELLER_POSITION_FILTER_ENABLED=
DIGISELLER_WEAK_POSITION_THRESHOLD=
DIGISELLER_WEAK_UNKNOWN_RANK_ENABLED=
DIGISELLER_WEAK_UNKNOWN_RANK_ABS_GAP=
DIGISELLER_WEAK_UNKNOWN_RANK_REL_GAP=
DIGISELLER_CHECK_INTERVAL=
DIGISELLER_FAST_CHECK_INTERVAL_MIN=
DIGISELLER_FAST_CHECK_INTERVAL_MAX=
DIGISELLER_COOLDOWN_SECONDS=
DIGISELLER_IGNORE_DELTA=
DIGISELLER_NOTIFY_SKIP=
DIGISELLER_NOTIFY_SKIP_COOLDOWN_SECONDS=
DIGISELLER_NOTIFY_COMPETITOR_CHANGE=
DIGISELLER_COMPETITOR_CHANGE_DELTA=
DIGISELLER_COMPETITOR_CHANGE_COOLDOWN_SECONDS=
DIGISELLER_UPDATE_ONLY_ON_COMPETITOR_CHANGE=
DIGISELLER_NOTIFY_PARSER_ISSUES=
DIGISELLER_PARSER_ISSUE_COOLDOWN_SECONDS=
DIGISELLER_HARD_FLOOR_ENABLED=
DIGISELLER_MAX_DOWN_STEP=
DIGISELLER_FAST_REBOUND_DELTA=
DIGISELLER_FAST_REBOUND_BYPASS_COOLDOWN=

# Конкуренты (список URL через запятую)
COMPETITOR_URLS=https://ggsel.net/catalog/product/competitor-12345
# Cookies для доступа к защищенным страницам (QRATOR/anti-bot)
# Формат: name1=value1; name2=value2
# Профильные ключи имеют приоритет над общим:
# GGSEL_COMPETITOR_COOKIES, DIGISELLER_COMPETITOR_COOKIES
GGSEL_COMPETITOR_COOKIES=
DIGISELLER_COMPETITOR_COOKIES=
COMPETITOR_COOKIES=
# Путь к файлу backup cookies (альтернатива COMPETITOR_COOKIES)
COMPETITOR_COOKIES_BACKUP_PATH=data/cookies_backup.json
# Путь к env-файлу, из которого scheduler подтягивает cookies в runtime
# (по умолчанию ".env" в текущей рабочей директории процесса)
ENV_FILE_PATH=.env

# RSC parser (stealth_requests + bs4)
RSC_MAX_RETRIES=2

# Основные настройки цен
MIN_PRICE=0.25
MAX_PRICE=10.0
DESIRED_PRICE=0.35
UNDERCUT_VALUE=0.0051

# Режим при достижении MIN_PRICE: FIXED или STEP_UP
MODE=FIXED
FIXED_PRICE=0.35
STEP_UP_VALUE=0.05

# Логика "слабой позиции" (включается при POSITION_FILTER_ENABLED=true)
WEAK_PRICE_CEIL_LIMIT=0.3
POSITION_FILTER_ENABLED=false
WEAK_POSITION_THRESHOLD=20
# Эвристика "слабого" min-конкурента при rank=N/A:
WEAK_UNKNOWN_RANK_ENABLED=true
WEAK_UNKNOWN_RANK_ABS_GAP=0.03
WEAK_UNKNOWN_RANK_REL_GAP=0.08

# Cooldown (секунды) - не менять цену чаще
COOLDOWN_SECONDS=30

# Ignore delta - не менять если разница меньше
IGNORE_DELTA=0.001

# Интервал проверки (секунды)
# Для быстрой реакции используйте 20..60 секунд
CHECK_INTERVAL=30
FAST_CHECK_INTERVAL_MIN=20
FAST_CHECK_INTERVAL_MAX=60

# Уведомления
# NOTIFY_SKIP=false уменьшает шум в Telegram (пропуски пишутся в логи/метрики)
NOTIFY_SKIP=false
NOTIFY_SKIP_COOLDOWN_SECONDS=300
# Уведомлять при изменении минимальной цены конкурента (с антиспамом)
NOTIFY_COMPETITOR_CHANGE=true
COMPETITOR_CHANGE_DELTA=0.0001
COMPETITOR_CHANGE_COOLDOWN_SECONDS=60
UPDATE_ONLY_ON_COMPETITOR_CHANGE=true
NOTIFY_PARSER_ISSUES=true
PARSER_ISSUE_COOLDOWN_SECONDS=300

# Защита от убытков
HARD_FLOOR_ENABLED=true
MAX_DOWN_STEP=0.03
FAST_REBOUND_DELTA=0.01
FAST_REBOUND_BYPASS_COOLDOWN=true

# Логирование
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
