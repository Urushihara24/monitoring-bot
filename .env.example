# Telegram Bot (получите у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=123456789

# GGSEL API
# Секретный API key (для /apilogin)
GGSEL_API_KEY=your_api_key_here
# Опционально: готовый access token (если хотите задать вручную)
GGSEL_ACCESS_TOKEN=
GGSEL_SELLER_ID=8175
GGSEL_PRODUCT_ID=your_product_id_here
GGSEL_LANG=ru-RU
# true = не запускаться, если API недоступен на старте
GGSEL_REQUIRE_API_ON_START=false

# Конкуренты (список URL через запятую)
COMPETITOR_URLS=https://ggsel.net/catalog/product/competitor-12345
# Cookies для доступа к защищенным страницам (QRATOR/anti-bot)
# Формат: name1=value1; name2=value2
COMPETITOR_COOKIES=
# Selenium режим с реальным Chrome-профилем
SELENIUM_USE_REAL_PROFILE=false
SELENIUM_CHROME_USER_DATA_DIR=
SELENIUM_CHROME_PROFILE_DIR=Default
SELENIUM_HEADLESS=true

# Основные настройки цен
MIN_PRICE=0.25
MAX_PRICE=10.0
DESIRED_PRICE=0.35
UNDERCUT_VALUE=0.0051

# Режим при достижении MIN_PRICE: FIXED или STEP_UP
MODE=FIXED
FIXED_PRICE=0.35
STEP_UP_VALUE=0.05

# Фильтр слабого конкурента (0 = отключено)
LOW_PRICE_THRESHOLD=0
WEAK_PRICE_CEIL_LIMIT=0.3
POSITION_FILTER_ENABLED=false
WEAK_POSITION_THRESHOLD=20

# Cooldown (секунды) - не менять цену чаще
COOLDOWN_SECONDS=30

# Ignore delta - не менять если разница меньше
IGNORE_DELTA=0.001

# Интервал проверки (секунды)
CHECK_INTERVAL=30

# Уведомления
# NOTIFY_SKIP=false уменьшает шум в Telegram (пропуски пишутся в логи/метрики)
NOTIFY_SKIP=false
NOTIFY_SKIP_COOLDOWN_SECONDS=300
# Уведомлять при изменении минимальной цены конкурента (с антиспамом)
NOTIFY_COMPETITOR_CHANGE=true
COMPETITOR_CHANGE_DELTA=0.0001
COMPETITOR_CHANGE_COOLDOWN_SECONDS=60

# Логирование
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
