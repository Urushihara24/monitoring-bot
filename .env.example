# Telegram Bot (получите у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=123456789

# GGSEL API
# Секретный API key (для /apilogin)
GGSEL_API_KEY=your_api_key_here
# Опционально: готовый access token (если хотите задать вручную)
GGSEL_ACCESS_TOKEN=
GGSEL_SELLER_ID=8175
GGSEL_PRODUCT_ID=your_product_id_here
GGSEL_LANG=ru-RU
# true = не запускаться, если API недоступен на старте
GGSEL_REQUIRE_API_ON_START=false
GGSEL_ENABLED=true

# DigiSeller API (второй профиль)
DIGISELLER_ENABLED=false
DIGISELLER_API_KEY=
DIGISELLER_ACCESS_TOKEN=
DIGISELLER_SELLER_ID=
DIGISELLER_PRODUCT_ID=
DIGISELLER_BASE_URL=https://api.digiseller.com/api
DIGISELLER_LANG=ru-RU
DIGISELLER_REQUIRE_API_ON_START=false
DIGISELLER_COMPETITOR_URLS=

# Конкуренты (список URL через запятую)
COMPETITOR_URLS=https://ggsel.net/catalog/product/competitor-12345
# Google Watchlist URL для fallback (если основной парсинг не работает)
# Например: Google Sheets published to web
WATCHLIST_URLS=
# Cookies для доступа к защищенным страницам (QRATOR/anti-bot)
# Формат: name1=value1; name2=value2
# Можно получить через scripts/update_competitor_cookies.py
COMPETITOR_COOKIES=
# Путь к файлу backup cookies (альтернатива COMPETITOR_COOKIES)
COMPETITOR_COOKIES_BACKUP_PATH=data/cookies_backup.json
# Selenium режим с реальным Chrome-профилем
SELENIUM_USE_REAL_PROFILE=false
SELENIUM_CHROME_USER_DATA_DIR=
SELENIUM_CHROME_PROFILE_DIR=Default
SELENIUM_HEADLESS=true

# Playwright fallback (для RSC парсера)
# Улучшенный обход anti-bot через headless браузер
RSC_USE_PLAYWRIGHT=true
RSC_USE_SELENIUM_FALLBACK=true
RSC_MAX_RETRIES=2

# Distill.io fallback (резервный парсер)
# Документация: https://distill.io/web-monitoring-api
#
# Режим 1: Distill Cloud API (платный, вебхуки)
# - Получите API key в личном кабинете Distill.io
# - Создайте мониторы для URL конкурентов
# - Укажите ID мониторов (через запятую)
DISTILL_API_KEY=
DISTILL_MONITOR_IDS=

# Режим 2: Локальный Distill Web Monitor (бесплатный)
# - Установите расширение Distill Web Monitor
# - Настройте мониторинг URL
# - Укажите путь к данным расширения
# Mac: ~/Library/Application Support/Distill Web Monitor/data/
# Windows: %APPDATA%/Distill Web Monitor/data/
DISTILL_LOCAL_DATA_DIR=

# Режим 3: Email уведомления (IMAP)
# - Настройте email уведомления в Distill.io
# - Укажите IMAP настройки для чтения писем
DISTILL_EMAIL_ENABLED=false
DISTILL_EMAIL_IMAP_SERVER=imap.gmail.com
DISTILL_EMAIL_IMAP_PORT=993
DISTILL_EMAIL_USERNAME=
DISTILL_EMAIL_PASSWORD=

# Основные настройки цен
MIN_PRICE=0.25
MAX_PRICE=10.0
DESIRED_PRICE=0.35
UNDERCUT_VALUE=0.0051

# Режим при достижении MIN_PRICE: FIXED или STEP_UP
MODE=FIXED
FIXED_PRICE=0.35
STEP_UP_VALUE=0.05

# Фильтр слабого конкурента (0 = отключено)
LOW_PRICE_THRESHOLD=0
WEAK_PRICE_CEIL_LIMIT=0.3
POSITION_FILTER_ENABLED=false
WEAK_POSITION_THRESHOLD=20

# Cooldown (секунды) - не менять цену чаще
COOLDOWN_SECONDS=30

# Ignore delta - не менять если разница меньше
IGNORE_DELTA=0.001

# Интервал проверки (секунды)
# Для быстрой реакции используйте 20..60 секунд
CHECK_INTERVAL=30
FAST_CHECK_INTERVAL_MIN=20
FAST_CHECK_INTERVAL_MAX=60

# Автообновление cookies (для обхода QRATOR)
# Если cookies протухли — автоматически запускается скрипт обновления
AUTO_UPDATE_COOKIES=false
COOKIES_EXPIRE_SECONDS=21600  # 6 часов
COOKIES_UPDATE_SCRIPT=scripts/cron_update_cookies.sh

# Уведомления
# NOTIFY_SKIP=false уменьшает шум в Telegram (пропуски пишутся в логи/метрики)
NOTIFY_SKIP=false
NOTIFY_SKIP_COOLDOWN_SECONDS=300
# Уведомлять при изменении минимальной цены конкурента (с антиспамом)
NOTIFY_COMPETITOR_CHANGE=true
COMPETITOR_CHANGE_DELTA=0.0001
COMPETITOR_CHANGE_COOLDOWN_SECONDS=60
NOTIFY_PARSER_ISSUES=true
PARSER_ISSUE_COOLDOWN_SECONDS=300

# Защита от убытков
HARD_FLOOR_ENABLED=true
MAX_DOWN_STEP=0.03
FAST_REBOUND_DELTA=0.01
FAST_REBOUND_BYPASS_COOLDOWN=true

# Логирование
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
